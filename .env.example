# ──────────────────────────────────────────────────────────────────────────────
# PeerLens Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
SYNC_DATABASE_URL=sqlite:///./dev.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://peerlens:secret@localhost:5432/peerlens
# SYNC_DATABASE_URL=postgresql://peerlens:secret@localhost:5432/peerlens

# ── Cache & Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Price Data ────────────────────────────────────────────────────────────────
# "mock"     — deterministic synthetic prices, no API needed (local dev)
# "yfinance" — free, may be rate-limited
# "polygon"  — production-grade, requires key
PRICE_SOURCE=mock
POLYGON_API_KEY=

# ── Estimates Data ────────────────────────────────────────────────────────────
# "mock" — deterministic synthetic estimates (no API key, always available)
# "fmp"  — Financial Modeling Prep (requires FMP_API_KEY with premium plan)
ESTIMATES_SOURCE=mock
FMP_API_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Required for POST /api/thesis (thesis card generation)
ANTHROPIC_API_KEY=

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PEERS=20/minute
RATE_LIMIT_THESIS=5/minute
RATE_LIMIT_SCREEN=30/minute

# ── Score Alerts ──────────────────────────────────────────────────────────────
SCORE_ALERT_DELTA_THRESHOLD=5.0
SCORE_HISTORY_RETAIN_DAYS=90

# ── Caching TTLs (seconds) ────────────────────────────────────────────────────
SCORE_CACHE_TTL=86400
THESIS_CACHE_TTL=21600

# ── General ───────────────────────────────────────────────────────────────────
ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of additional allowed origins (e.g. Vercel deployment URL)
# ALLOWED_ORIGINS=https://your-app.vercel.app https://your-custom-domain.com
ALLOWED_ORIGINS=
